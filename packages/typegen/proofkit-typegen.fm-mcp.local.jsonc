{
  "$schema": "https://proofkit.dev/typegen-config-schema.json",
  "config": {
    "type": "fmdapi",
    "webviewerScriptName": "execute_data_api",
    "fmMcp": {
      "enabled": true,
      "connectedFileName": "MCP_Test"
    },
    "layouts": [
      {
        "layoutName": "Contacts",
        "schemaName": "contacts"
      }
    ],
    "path": "packages/typegen/live-fm-mcp-output",
    "validator": "zod/v4",
    "generateClient": true
  }
}
