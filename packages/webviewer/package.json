{
  "name": "@proofkit/webviewer",
  "version": "3.0.7-beta.2",
  "description": "A utility to fetch data from FileMaker webviewer",
  "type": "module",
  "files": [
    "dist",
    "skills",
    "bin",
    "!skills/_artifacts"
  ],
  "private": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/main.d.ts",
        "default": "./dist/esm/main.js"
      },
      "require": {
        "types": "./dist/cjs/main.d.cts",
        "default": "./dist/cjs/main.cjs"
      }
    },
    "./adapter": {
      "import": {
        "types": "./dist/esm/adapter.d.ts",
        "default": "./dist/esm/adapter.js"
      },
      "require": {
        "types": "./dist/cjs/adapter.d.cts",
        "default": "./dist/cjs/adapter.cjs"
      }
    },
    "./vite-plugins": {
      "import": {
        "types": "./dist/esm/vite-plugins.d.ts",
        "default": "./dist/esm/vite-plugins.js"
      },
      "require": {
        "types": "./dist/cjs/vite-plugins.d.cts",
        "default": "./dist/cjs/vite-plugins.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.4",
    "@proofkit/fmdapi": "workspace:*",
    "@tanstack/intent": "^0.0.19",
    "@tanstack/vite-config": "^0.2.1",
    "@types/filemaker-webviewer": "^1.0.3",
    "@types/node": "^22.19.5",
    "@types/uuid": "^10.0.0",
    "knip": "^5.80.2",
    "publint": "^0.3.16",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc",
    "build": "tsc && vite build && publint --strict",
    "build:watch": "tsc && vite build --watch",
    "dev": "vite",
    "check-exports": "attw --pack .",
    "release": "pnpm build && changeset publish --access public",
    "knip": "knip",
    "lint": "biome check . --write",
    "lint:summary": "biome check . --reporter=summary"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proofgeist/proofkit.git"
  },
  "author": "Todd Geist",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/proofgeist/proofkit/issues"
  },
  "homepage": "https://proofkit.dev/docs/webviewer",
  "keywords": [
    "filemaker",
    "proofgeist",
    "webviewer",
    "fm",
    "tanstack-intent"
  ],
  "bin": {
    "intent": "./bin/intent.js"
  }
}
